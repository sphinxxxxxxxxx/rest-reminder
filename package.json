{
  "name": "rest-reminder",
  "version": "1.0.4",
  "description": "沉浸式防作弊休息提醒器",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.example.restreminder",
    "productName": "Rest Reminder",
    "directories": { "output": "dist" },
    "win": { "target": "nsis", "icon": "build/icon.ico" },
    "mac": { "target": "dmg", "icon": "build/icon.icns" },
    "nsis": { 
      "oneClick": false, 
      "allowToChangeInstallationDirectory": true, 
      "perMachine": true, 
      "createDesktopShortcut": true 
    },
    "extraResources": [ { "from": "build/icon.png", "to": "icon.png" } ]
  }
}
